grid <- expand.grid(
intentionality = seq(min(annot_z$intentionality), max(annot_z$intentionality), length.out = 50),
factivity = seq(min(annot_z$factivity), max(annot_z$factivity), length.out = 50),
pictoriality = median(annot_z$pictoriality)
)
probs <- as.data.frame(predict(mod, newdata = grid, type = "probs"))
grid <- cbind(grid, probs)
grid_long <- pivot_longer(grid, cols = c("1","2","3"), names_to = "cluster", values_to = "prob")
ggplot(grid_long, aes(x = intentionality, y = factivity, fill = prob)) +
geom_tile() +
facet_wrap(~ cluster, ncol = 1) +
scale_fill_viridis_c(option = "magma") +
labs(x = "Intentionality (z-score)",
y = "Factivity (z-score)",
fill = "Predicted probability",
title = "Cluster probabilities across Intentionality × Factivity") +
theme_minimal()
