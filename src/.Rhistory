# Define all predictor pairs
predictor_pairs <- list(
c("intentionality", "factivity", "pictoriality"),
c("intentionality", "pictoriality", "factivity"),
c("factivity", "pictoriality", "intentionality")
)
# Loop over pairs to create grids and predicted probabilities
heatmap_list <- list()
for(i in seq_along(predictor_pairs)){
x_var <- predictor_pairs[[i]][1]
y_var <- predictor_pairs[[i]][2]
fixed_var <- predictor_pairs[[i]][3]
# Grid for plotting
grid <- expand.grid(
x = seq(min(annot_z[[x_var]]), max(annot_z[[x_var]]), length.out = 50),
y = seq(min(annot_z[[y_var]]), max(annot_z[[y_var]]), length.out = 50)
)
# Fix third variable at median
grid[[fixed_var]] <- median(annot_z[[fixed_var]])
# Predicted probabilities
probs <- as.data.frame(predict(mod, newdata = grid, type = "probs"))
# Add x, y for ggplot
grid <- cbind(grid, probs)
# Convert to long format for ggplot
grid_long <- pivot_longer(grid, cols = c("1","2","3"), names_to = "cluster", values_to = "prob")
# Add identifiers for heatmap_list
grid_long$x_var <- x_var
grid_long$y_var <- y_var
heatmap_list[[i]] <- grid_long
}
