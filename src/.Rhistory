library(plot3D)
library(nnet)
# Suppose df_clean$sense contains the 3 clusters from GMM
annot_z$sense <- factor(annot_z$sense)
library(readxl)
library(dplyr)
library(mclust)
library(ggplot2)
library(reshape2)
library(scatterplot3d)
rm(list = ls())
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
# Load data
df <- read_xlsx("../input/corpus_annotated.xlsx", sheet = 1)
names(df) <- gsub("\\smeans", "", tolower(names(df)))
# Drop excluded snippets and those with too little information
df <- df %>% mutate(across(ends_with("ity"), ~ as.numeric(.))) # will introduce NAs for X and E
df <- na.omit(df)
# Select only the annotation dimensions
annot <- df %>%
select(intentionality, factivity, pictoriality)
# Check ranges (should be within 1–7 or slightly outside if averaged)
apply(annot, 2, range)
# Pairwise correlations
cor(annot, use = "pairwise.complete.obs")
# Distributions
annot_long <- melt(annot) # Long form
ggplot(annot_long, aes(x = value, fill = variable)) +
geom_histogram(binwidth=0.5) +
facet_wrap(~ variable) +
theme_light()
# Standardize annotation space
annot_z <- as.data.frame(scale(annot))
scatterplot3d(annot_z$intentionality,
annot_z$factivity,
annot_z$pictoriality,
pch=19, color="blue")
# Distributions scaled
annot_z_long <- melt(annot_z) # Long form
ggplot(annot_z_long, aes(x = value, fill = variable)) +
geom_histogram(binwidth=0.5) +
facet_wrap(~ variable) +
theme_light()
# Clustering
gmm_res <- Mclust(annot_z, G = 1:3)
summary(gmm_res)
# Cluster assignments
annot_z$sense <- gmm_res$classification
# Posterior probabilities (membership confidence)
annot_z$posterior_max <- apply(gmm_res$z, 1, max)
# Check cluster means
aggregate(cbind(intentionality, factivity, pictoriality) ~ sense, data = annot_z, mean)
# BIC values
plot(gmm_res, what = "BIC",
main = "BIC for Gaussian mixture models")
# PCA
pca_res <- prcomp(annot_z, center = FALSE, scale. = FALSE)
# Variance explained
summary(pca_res)
# Combine clustering with PCA
pca_res <- bind_cols(pca_res$x, annot_z)
ggplot(pca_res, aes(PC1, PC2, color = as.factor(sense))) +
geom_point(alpha = 0.6) +
labs(title = "PCA of annotation space with latent sense clusters",
color = "Sense") +
theme_minimal()
scatterplot3d(annot_z$intentionality,
annot_z$factivity,
annot_z$pictoriality,
pch=19, color=annot_z$sense)
# Suppose df_clean$sense contains the 3 clusters from GMM
annot_z$sense <- factor(annot_z$sense)
# Fit multinomial logistic regression
mod <- multinom(sense ~ intentionality * factivity * pictoriality, data = annot_z)
summary(mod)
prob_df <- as.data.frame(predict(mod, type="probs"))
prob_df$intentionality <- annot_$intentionality
prob_df$intentionality <- annot_z$intentionality
prob_df_long <- pivot_longer(prob_df, cols = starts_with("V"), names_to = "cluster", values_to = "prob")
# Grid of predictor values (sequence along 2 dimensions, fix third at median)
grid <- expand.grid(
intentionality = seq(min(annot_z$intentionality), max(annot_z$intentionality), length.out = 50),
factivity = seq(min(annot_z$factivity), max(annot_z$factivity), length.out = 50),
pictoriality = median(annot_z$pictoriality)
)
# Predicted probabilities
probs <- as.data.frame(predict(mod, newdata = grid, type = "probs"))
probs
library(plotly)
grid$cluster1_prob <- probs$V1  # pick one cluster
grid
plot_ly(grid, x = ~intentionality, y = ~factivity, z = ~cluster1_prob, type = "surface")
grid$cluster1_prob <- probs$V1  # pick one cluster
plot_ly(grid, x = ~intentionality, y = ~factivity, z = ~cluster1_prob, type = "surface")
grid$cluster1_prob <- probs$V1  # pick one cluster
grid
probs$V1
