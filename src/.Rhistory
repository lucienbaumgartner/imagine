library(glmnet)
# Prepare data
x <- as.matrix(annot_z[, c("intentionality", "factivity", "pictoriality")])
y <- annot_z$sense
# Fit multinomial with L2 (ridge) regularization for stability
cv_fit <- cv.glmnet(
x, y,
family = "multinomial",
alpha = 0,           # 0 = ridge, 1 = lasso
type.measure = "class" # misclassification
)
best_lambda <- cv_fit$lambda.min
fit <- glmnet(x, y, family = "multinomial", alpha = 0, lambda = best_lambda)
coefs <- coef(fit)
coefs$`1`  # coefficients for cluster 1
coefs$`2`  # coefficients for cluster 2
coefs$`3`  # coefficients for cluster 3
x_int <- model.matrix(~ (intentionality + factivity + pictoriality)^2, data = annot_z)[,-1]
cv_fit_int <- cv.glmnet(x_int, y, family = "multinomial", alpha = 0, type.measure = "class")
coefs <- coef(cv_fit_int)
coef_df <- as.data.frame(do.call(rbind, lapply(coefs, function(x) as.vector(x[-1]))))
coef_df$cluster <- factor(1:3)
coef_long <- pivot_longer(coef_df, cols = -cluster, names_to = "predictor", values_to = "coef")
ggplot(coef_long, aes(x = predictor, y = coef, fill = cluster)) +
geom_bar(stat = "identity", position = "dodge") +
theme_minimal()
coef_df
coef_df <- as.data.frame(do.call(rbind, lapply(coefs, function(x) as.vector(x[-1]))))
coef_df
coefs <- coef(cv_fit_int)
coefs
names(coef_df) <- rownames(coefs$`1`)
names(coef_df) <- rownames(coefs$`1`[-1])
coef_df$cluster <- factor(1:3)
coef_long <- pivot_longer(coef_df, cols = -cluster, names_to = "predictor", values_to = "coef")
coef_df <- as.data.frame(do.call(rbind, lapply(coefs, function(x) as.vector(x[-1]))))
names(coef_df) <- rownames(coefs$`1`[-1])
coef_df$cluster <- factor(1:3)
coef_long <- pivot_longer(coef_df, cols = -cluster, names_to = "predictor", values_to = "coef")
