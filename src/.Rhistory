plot_ly(grid, x = ~intentionality, y = ~factivity, z = ~cluster1_prob, type = "surface")
grid
# Grid dimensions
nx <- 50
ny <- 50
# Reshape cluster probabilities into a matrix
z_matrix <- matrix(probs$`1`, nrow = nx, ncol = ny)
# Plot surface
plot_ly(x = seq(min(annot_z$intentionality), max(annot_z$intentionality), length.out = nx),
y = seq(min(annot_z$factivity), max(annot_z$factivity), length.out = ny),
z = z_matrix,
type = "surface") %>%
layout(scene = list(
xaxis = list(title = "Intentionality"),
yaxis = list(title = "Factivity"),
zaxis = list(title = "Cluster 1 Probability")
))
